<!DOCTYPE html>
<html>
  <head>
    <title>マップに地点表示</title>
    <style>
      #map {
        height: 100vh;
        width: 80%;
        float: left;
      }
      #sidebar {
        width: 20%;
        height: 100vh;
        float: left;
        overflow-y: auto;
        padding: 10px;
        box-sizing: border-box;
        background: #f0f0f0;
      }
      .info-item {
        margin-bottom: 15px;
        border-bottom: 1px solid #ccc;
        padding-bottom: 10px;
      }
    </style>
    <script>
      async function initMap() {
        const map = new google.maps.Map(document.getElementById("map"), {
          zoom: 10,
          center: { lat: 35.6762, lng: 139.6503 },
          gestureHandling: "greedy"
        });

        const response = await fetch("https://script.google.com/macros/s/AKfycbx4quC0_dVaqYma6jBVIqj6_Kt5RHpHDvF4GVxF7UKrELpL7UC44H7D9xg3p0h_hGrZOg/exec");
        const data = await response.json();

        const infoWindow = new google.maps.InfoWindow();
        const sidebar = document.getElementById("sidebar");

        data.forEach(place => {
          const name = place["行った現場の名前を教えてください"];
          const lat = place.lat;
          const lng = place.lng;
          const extraInfo = place.info && place.info["そのほかの情報"] ? place.info["そのほかの情報"] : "情報なし";

          const marker = new google.maps.Marker({
            position: { lat, lng },
            map,
            title: name
          });

          const content = `
            <div>
              <strong>${name}</strong><br>
              <strong>${extraInfo}</strong>
            </div>
          `;

          // マウスオーバーで吹き出し表示
          marker.addListener("mouseover", () => {
            infoWindow.setContent(content);
            infoWindow.open(map, marker);
          });

          marker.addListener("mouseout", () => {
            infoWindow.close();
          });

          // サイドバー表示
          const div = document.createElement("div");
          div.className = "info-item";
          div.innerHTML = `
            <strong>${name}</strong><br>
            緯度: ${lat}<br>
            経度: ${lng}<br>
            補足情報: ${extraInfo}
          `;
          sidebar.appendChild(div);
        });
      }
    </script>
    <script async defer
      src="https://maps.googleapis.com/maps/api/js?key=AIzaSyClN0LeQjAs9IYscEvrjqzT29G1efRkJK0&callback=initMap">
    </script>
  </head>
  <body>
    <div id="sidebar"></div>
    <div id="map"></div>
  </body>
</html>
